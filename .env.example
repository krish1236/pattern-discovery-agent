# Copy to .env and fill in (do not commit .env)
ANTHROPIC_API_KEY=
# Optional model overrides (defaults: claude-haiku-4-5, claude-sonnet-4-6)
# ANTHROPIC_EXTRACTION_MODEL=
# ANTHROPIC_EXTRACTION_MAX_TOKENS=8192
# ANTHROPIC_CONTRADICTION_MODEL=
# Optional: Sonnet (or other) for verify-step pattern interpretations in reports
# ANTHROPIC_INTERPRETATION_MODEL=claude-sonnet-4-6
OPENALEX_API_KEY=
# Optional politeness pool (OpenAlex User-Agent mailto:); alias OPENALEX_EMAIL
OPENALEX_MAILTO=
# Optional: restrict /works search to one OpenAlex concept (e.g. C41008148 = Computer Science).
# Leave unset for cross-disciplinary topics (Bitcoin, policy, medicine + CS, etc.).
# OPENALEX_SEARCH_CONCEPT_ID=C41008148
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_TOKEN=
TAVILY_API_KEY=

# Optional: pytest live connector tests (tests/packs/research/test_connectors_live.py)
# RUN_LIVE_CONNECTOR_TESTS=1

# After running: python scripts/run_evaluation.py
# Optional: EVAL_DIR=eval_output/<timestamp> pytest tests/quality/ -m quality -v
