# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
.env/
.python-version

# Environment and secrets (never commit)
.env
.env.*
!.env.example

# Packaging / build
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.egg
MANIFEST

# Test / coverage / type check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.tox/
.nox/
hypothesis/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Downloaded models and heavy ML caches (local dev; repo-root only — not $HOME)
.cache/
*.pt
*.pth
*.onnx
*.bin
*.safetensors

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors and IDEs
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

.vscode/

# Cursor (local index / context rules; not shared)
.cursorignore

# Logs and local scratch
*.log
logs/
tmp/
temp/
*.tmp

# Documentation build outputs (keep tracked: docs/*.md sources)
docs/_build/
site/
.doctrees/

# RunForge / local agent runtime storage (if created under project)
.agent_runtime/

# Local evaluation runs (scripts/run_evaluation.py; --output-dir defaults here)
eval_output/
outputs/
run_output/

# Serialized / scratch data (local experiments)
*.pkl
*.pickle

# ML experiment tracking (if used)
wandb/

# macOS resource forks
._*
